{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo Xenia hearth -- 10 heads + Echo loaded (Xun converts Kan into Dui)",
            "timeout": 5
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Task|Agent",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -File .claude/hooks/pre-dispatch-budget.ps1",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Write|mcp__.*xenia.*output_write",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -File .claude/hooks/pre-response-redaction.ps1",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "mcp__.*ticket.*",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -File .claude/hooks/pre-tool-privilege.ps1",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/pre-tool-privilege.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|mcp__.*xenia.*output_write",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -File .claude/hooks/post-output-sla-stamp.ps1",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
